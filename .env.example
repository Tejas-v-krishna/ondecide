# OnDecide — Local Environment
# Copy this file to .env.local and fill in your actual keys

# ── Clerk Authentication ──────────────────────────────────────
# Get from: https://dashboard.clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_SECRET_KEY=sk_test_

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ── Supabase Database ─────────────────────────────────────────
# Get from: https://app.supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── Finnhub Market Data ───────────────────────────────────────
# Get from: https://finnhub.io → Dashboard → API Key
# Free tier: 60 calls/minute (sufficient for single-user dev)
FINNHUB_API_KEY=

# ── Tavily Search ─────────────────────────────────────────────
# Get from: https://app.tavily.com → API Keys
TAVILY_API_KEY=tvly-

# ── Google Gemini (AI) ────────────────────────────────────────
# Get from: https://aistudio.google.com → Get API Key
GOOGLE_API_KEY=
